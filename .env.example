# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://refinery:refinery@localhost:5432/refinery

# ─── API 인증 (백엔드·프론트·에이전트 공유) ────────────────────────────────────
API_KEY=change-me-to-a-secure-random-string

# ─── Anthropic (선택 — 주간 LLM 인사이트) ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=3001
OTLP_HTTP_PORT=4318
LOG_LEVEL=info
NODE_ENV=development

# ─── 데이터 보존 기간 (기본 90일) ──────────────────────────────────────────────
RETENTION_DAYS=90

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Agent (개발 PC에서 설정) ───────────────────────────────────────────────────
CC_INSIGHTS_SERVER=http://your-homeserver:3001

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
